# Database connection string (Postgres)
DATABASE_URL=postgresql://postgres:root@127.0.0.1:5432/your-database-name

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# S3 media storage. In development this points at a local S3-compatible mock
# (e.g. floci, running on port 4566) so uploads never touch a real bucket.
# Point these at real AWS credentials in production (omit S3_ENDPOINT for
# real AWS so it uses the standard virtual-hosted-style endpoints).
# S3_PREFIX is optional and namespaces all media keys under a folder, e.g.
# "dev-assets" so objects are stored at "dev-assets/<filename>".
S3_BUCKET=payload-media
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:4566
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
S3_PREFIX=
