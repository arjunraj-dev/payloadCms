\":1920,\"height\":1360,\"mimeType\":\"image/webp\",\"filesize\":83916,\"filename\":\"In-progress-1920x1360.webp\"},\"og\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/In-progress-1200x630.webp\",\"width\":1200,\"height\":630,\"mimeType\":\"image/webp\",\"filesize\":42252,\"filename\":\"In-progress-1200x630.webp\"}}}},{\"id\":\"6a4565d8086e83eb4bf5bd13\",\"title\":\"Coming\",\"description\":\"Confirmed, being prepared.\",\"icon\":\"calendar\",\"color\":\"#A17D4D\",\"image\":{\"id\":17,\"alt\":\"Coming\",\"caption\":null,\"prefix\":\"dev-assets\",\"folder\":null,\"updatedAt\":\"2026-07-01T19:09:12.296Z\",\"createdAt\":\"2026-07-01T19:09:12.296Z\",\"url\":\"https://dl0cve36duziq.cloudfront.net/coming.webp\",\"thumbnailURL\":\"/api/media/file/coming-300x200.webp\",\"filename\":\"coming.webp\",\"mimeType\":\"image/webp\",\"filesize\":166672,\"width\":4096,\"height\":2731,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumbnail\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/coming-300x200.webp\",\"width\":300,\"height\":200,\"mimeType\":\"image/webp\",\"filesize\":4926,\"filename\":\"coming-300x200.webp\"},\"square\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/coming-500x500.webp\",\"width\":500,\"height\":500,\"mimeType\":\"image/webp\",\"filesize\":13602,\"filename\":\"coming-500x500.webp\"},\"small\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/coming-600x400.webp\",\"width\":600,\"height\":400,\"mimeType\":\"image/webp\",\"filesize\":13060,\"filename\":\"coming-600x400.webp\"},\"medium\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/coming-900x600.webp\",\"width\":900,\"height\":600,\"mimeType\":\"image/webp\",\"filesize\":22984,\"filename\":\"coming-900x600.webp\"},\"large\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/coming-1400x933.webp\",\"width\":1400,\"height\":933,\"mimeType\":\"image/webp\",\"filesize\":41400,\"filename\":\"coming-1400x933.webp\"},\"xlarge\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/coming-1920x1280.webp\",\"width\":1920,\"height\":1280,\"mimeType\":\"image/webp\",\"filesize\":61398,\"filename\":\"coming-1920x1280.webp\"},\"og\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/coming-1200x630.webp\",\"width\":1200,\"height\":630,\"mimeType\":\"image/webp\",\"filesize\":27528,\"filename\":\"coming-1200x630.webp\"}}}},{\"id\":\"6a4565d8086e83eb4bf5bd14\",\"title\":\"Planned\",\"description\":\"On the roadmap.\",\"icon\":\"lightbulb\",\"color\":\"#1F2937\",\"image\":{\"id\":14,\"alt\":\"Planned\",\"caption\":null,\"prefix\":\"dev-assets\",\"folder\":null,\"updatedAt\":\"2026-07-01T19:09:12.272Z\",\"createdAt\":\"2026-07-01T19:09:12.272Z\",\"url\":\"https://dl0cve36duziq.cloudfront.net/planned.webp\",\"thumbnailURL\":\"/api/media/file/planned-300x213.webp\",\"filename\":\"planned.webp\",\"mimeType\":\"image/webp\",\"filesize\":188326,\"width\":4096,\"height\":2902,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumbnail\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/planned-300x213.webp\",\"width\":300,\"height\":213,\"mimeType\":\"image/webp\",\"filesize\":1712,\"filename\":\"planned-300x213.webp\"},\"square\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/planned-500x500.webp\",\"width\":500,\"height\":500,\"mimeType\":\"image/webp\",\"filesize\":11454,\"filename\":\"planned-500x500.webp\"},\"small\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/planned-600x425.webp\",\"width\":600,\"height\":425,\"mimeType\":\"image/webp\",\"filesize\":9352,\"filename\":\"planned-600x425.webp\"},\"medium\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/planned-900x638.webp\",\"width\":900,\"height\":638,\"mimeType\":\"image/webp\",\"filesize\":19224,\"filename\":\"planned-900x638.webp\"},\"large\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/planned-1400x992.webp\",\"width\":1400,\"height\":992,\"mimeType\":\"image/webp\",\"filesize\":40558,\"filename\":\"planned-1400x992.webp\"},\"xlarge\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/planned-1920x1360.webp\",\"width\":1920,\"height\":1360,\"mimeType\":\"image/webp\",\"filesize\":66208,\"filename\":\"planned-1920x1360.webp\"},\"og\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/planned-1200x630.webp\",\"width\":1200,\"height\":630,\"mimeType\":\"image/webp\",\"filesize\":30328,\"filename\":\"planned-1200x630.webp\"}}}}]},\"modernizeGovernment\":{\"title\":\"Modernize Government\",\"description\":\"Making government faster, simpler, and more effective — so it works for you, not against you.\",\"cards\":[{\"id\":\"6a4565d8086e83eb4bf5bd15\",\"icon\":\"folder\",\"label\":\"LIVE\",\"labelColor\":\"green\",\"title\":\"MyGateway\",\"description\":\"The Government's unified digital services platform — one place to access government services online, from anywhere. MyGateway already hosts 168 government services and has more than 135,000 registered users, with around 4,000 transactions processed every month. And we're not stopping there — a modernization programme is actively underway to make the platform easier to use, interoperable and more secure. Link: mygateway.gov.bs\"},{\"id\":\"6a4565d8086e83eb4bf5bd16\",\"icon\":\"folder\",\"label\":\"IN PROGRESS\",\"labelColor\":\"blue\",\"title\":\"Microsoft 365 Rollout\",\"description\":\"Modernizing how government works on the inside. Rolling out Microsoft 365 — including Teams, SharePoint, Copilot AI and OneDrive — across the public service to improve collaboration, reduce paperwork, and give public servants the tools they need to do their jobs well. A more productive public service means better service for Bahamians.\"},{\"id\":\"6a4565d8086e83eb4bf5bd17\",\"icon\":\"folder\",\"label\":\"COMING\",\"labelColor\":\"orange\",\"title\":\"Digital Policy Framework\",\"description\":\"Applying for a police certificate is one of the most common interactions Bahamians have with government. We're making it digital — so you can apply online, track your application, and receive your certificate without visiting a station. The pilot is ready; rollout is being prepared.\"},{\"id\":\"6a4565d8086e83eb4bf5bd18\",\"icon\":\"folder\",\"label\":\"COMING\",\"labelColor\":\"orange\",\"title\":\"National Digital ID\",\"description\":\"Proving who you are to your own government shouldn't mean carrying a stack of documents from one office to the next. A national digital ID changes that — one trusted, secure credential to access services, sign documents, and receive what you're owed. Built carefully, with privacy and security at its core.\"},{\"id\":\"6a4565d8086e83eb4bf5bd19\",\"icon\":\"folder\",\"label\":\"PLANNED\",\"labelColor\":\"planned\",\"title\":\"Smart Government Portal\",\"description\":\"A suite of AI-powered tools built for the public service — designed to help public officers work smarter, draft faster, and spend less time on administrative tasks and more time serving Bahamians. Includes tools for briefings, correspondence, research, and meeting management.\"}]},\"buildFutureReadiness\":{\"title\":\"Build Future Readiness\",\"description\":\"Preparing the country for what's ahead — starting with the foundations that make sure new technology serves Bahamians, not the other way around. From our first AI strategy to the foundations of a more connected country, these priorities are well underway.\",\"cards\":[{\"id\":\"6a4565d8086e83eb4bf5bd1a\",\"icon\":\"cpu\",\"label\":\"IN PROGRESS\",\"labelColor\":\"blue\",\"title\":\"WiFi in The Parks\",\"description\":\"Free public WiFi in parks and public spaces across The Bahamas — because connectivity is infrastructure, and infrastructure should be accessible to everyone. 83 locations are already live, with 131 more in the planning phase.\"},{\"id\":\"6a4565d8086e83eb4bf5bd1b\",\"icon\":\"graduation-cap\",\"label\":\"COMING\",\"labelColor\":\"orange\",\"title\":\"National Artificial Intelligence Committee\",\"description\":\"The body that will guide how The Bahamas adopts and governs artificial intelligence. The Committee brings together government, industry, and expertise to develop the national AI strategy, establish governance standards, and ensure AI works in the interest of Bahamians. Establishment is being prepared.\"},{\"id\":\"6a4565d8086e83eb4bf5bd1c\",\"icon\":\"book-open\",\"label\":\"PLANNED\",\"labelColor\":\"planned\",\"title\":\"Bahamas AI Skills Initiative\",\"description\":\"A national programme to give every Bahamian access to AI literacy and AI training. The goal is practical: equip Bahamians with the knowledge to use AI tools confidently, compete in an AI-powered economy, and participate in the industries being built around them.\"},{\"id\":\"6a4565d8086e83eb4bf5bd1d\",\"icon\":\"smartphone\",\"label\":\"PLANNED\",\"labelColor\":\"planned\",\"title\":\"Bahamas Future Skills Academy\",\"description\":\"A national platform — online and in-person — offering training in the skills the future demands: artificial intelligence, data analytics, cybersecurity, software development, and more. Designed to reach Bahamians on every island, at every stage of their career.\\n\"}]},\"developBahamianTalent\":{\"title\":\"Develop Bahamian Talent\",\"description\":\"Equipping Bahamians with the skills for tomorrow — because a nation that doesn't invest in its talent is a nation that doesn't have a future.\",\"backgroundImage\":{\"id\":15,\"alt\":\"Develop Bahamian Talent\",\"caption\":null,\"prefix\":\"dev-assets\",\"folder\":null,\"updatedAt\":\"2026-07-01T19:09:12.282Z\",\"createdAt\":\"2026-07-01T19:09:12.281Z\",\"url\":\"https://dl0cve36duziq.cloudfront.net/develop.webp\",\"thumbnailURL\":\"/api/media/file/develop-300x200.webp\",\"filename\":\"develop.webp\",\"mimeType\":\"image/webp\",\"filesize\":166672,\"width\":4096,\"height\":2731,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumbnail\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/develop-300x200.webp\",\"width\":300,\"height\":200,\"mimeType\":\"image/webp\",\"filesize\":4926,\"filename\":\"develop-300x200.webp\"},\"square\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/develop-500x500.webp\",\"width\":500,\"height\":500,\"mimeType\":\"image/webp\",\"filesize\":13602,\"filename\":\"develop-500x500.webp\"},\"small\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/develop-600x400.webp\",\"width\":600,\"height\":400,\"mimeType\":\"image/webp\",\"filesize\":13060,\"filename\":\"develop-600x400.webp\"},\"medium\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/develop-900x600.webp\",\"width\":900,\"height\":600,\"mimeType\":\"image/webp\",\"filesize\":22984,\"filename\":\"develop-900x600.webp\"},\"large\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/develop-1400x933.webp\",\"width\":1400,\"height\":933,\"mimeType\":\"image/webp\",\"filesize\":41400,\"filename\":\"develop-1400x933.webp\"},\"xlarge\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/develop-1920x1280.webp\",\"width\":1920,\"height\":1280,\"mimeType\":\"image/webp\",\"filesize\":61398,\"filename\":\"develop-1920x1280.webp\"},\"og\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/develop-1200x630.webp\",\"width\":1200,\"height\":630,\"mimeType\":\"image/webp\",\"filesize\":27528,\"filename\":\"develop-1200x630.webp\"}}},\"cards\":[{\"id\":\"6a4565d8086e83eb4bf5bd1d\",\"icon\":\"lightbulb\",\"label\":\"IN PROGRESS\",\"labelColor\":\"blue\",\"title\":\"National AI Literacy Initiative\",\"description\":\"A foundational understanding of artificial intelligence — what it is, how it works, and how to use it responsibly — made available to Bahamians at every level, from first steps to advanced mastery. Training will be offered both online and in person, across the public service and the country as a whole.\"},{\"id\":\"6a4565d8086e83eb4bf5bd1e\",\"icon\":\"graduation-cap\",\"label\":\"PLANNED\",\"labelColor\":\"planned\",\"title\":\"Bahamas AI Skills Initiative\",\"description\":\"A national programme to give every Bahamian access to AI literacy and AI training. The goal is practical: equip Bahamians with the knowledge to use AI tools confidently, compete in an AI-shaped economy, and participate in the industries being built around them.\"},{\"id\":\"6a4565d8086e83eb4bf5bd1f\",\"icon\":\"book-open\",\"label\":\"PLANNED\",\"labelColor\":\"planned\",\"title\":\"Bahamas Future Skills Academy\",\"description\":\"A national platform — online and in-person — offering training in the skills the future demands: artificial intelligence, data analytics, cybersecurity, software development, and more. Designed to reach Bahamians on every island, at every stage of their career.\"}]},\"driveNationalDevelopment\":{\"title\":\"Drive National Development\",\"description\":\"Turning national priorities into measurable outcomes. Building the living plan, the institutions, and the accountability systems that make sure work actually gets done — and that progress can be tracked and verified.\",\"cards\":[{\"id\":\"6a4565d8086e83eb4bf5bd20\",\"icon\":\"target\",\"label\":\"IN PROGRESS\",\"labelColor\":\"green\",\"title\":\"Renewing Vision 2040\",\"description\":\"Vision 2040 set the course for The Bahamas. This Ministry is built to renew that vision and help deliver it. A review of the national development plan is underway — engaging ministries, agencies, and stakeholders — with an updated framework targeted for the end of this year. [NEEDS SPECIFICS — confirm end-2026 target date before publishing]\"},{\"id\":\"6a4565d8086e83eb4bf5bd21\",\"icon\":\"building\",\"label\":\"COMING\",\"labelColor\":\"orange\",\"title\":\"National Planning and Development Institute\",\"description\":\"Our national development plan has struggled to survive changes in political leadership — starting over each cycle rather than building on what came before. This Institute is designed to change that: an independent statutory body, accountable to Parliament, with dedicated staff to steward the national plan, measure progress, and hold delivery to account — beyond the reach of any political cycle. [NEEDS SPECIFICS — confirm Cabinet/legislative timeline before badge reads \\\"Coming\\\" publicly]\"},{\"id\":\"6a4565d8086e83eb4bf5bd22\",\"icon\":\"bar-chart\",\"label\":\"PLANNED\",\"labelColor\":\"planned\",\"title\":\"National Delivery Dashboard\",\"description\":\"A public, live dashboard tracking the Government's progress against national priorities — so every Bahamian can see what has been committed to and where things stand. This is the accountability infrastructure the country has needed: not just a plan, but a visible, honest record of delivery.\"}]},\"countryFuture\":{\"heading\":\"This page moves when we do.\",\"subtitle\":\"As each program, initiative, and policy moves from 'Planned' to 'Live', this page moves with it. This is the direction we share to show what we're working on, and how it's going.\",\"pillarsHeading\":\"Three pillars. One purpose.\",\"pillarsDescription\":\"Modernizing government, preparing people for the future, and delivering on national priorities — all of it points in the same direction: more opportunity for more Bahamians. Wherever you live. Whatever you're building. However you got here.\",\"footerText\":\"If you want to be part of the work — not just watch it — we want to hear from you.\",\"primaryButton\":{\"label\":\"Get involved →\",\"href\":\"/get-involved\"}},\"updatedAt\":\"2026-07-05T09:21:33.492Z\",\"createdAt\":\"2026-07-01T19:09:12.696Z\",\"globalType\":\"progress-page\"}","status":200,"url":""},"revalidate":31536000,"tags":["global_progress-page"]}