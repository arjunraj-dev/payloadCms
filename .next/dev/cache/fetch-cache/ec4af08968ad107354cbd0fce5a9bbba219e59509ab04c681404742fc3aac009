{"kind":"FETCH","data":{"headers":{},"body":"{\"id\":1,\"hero\":{\"title\":\"A new Ministry. A clear mandate.\",\"subtitle\":[{\"id\":\"6a4565d8086e83eb4bf5bce9\",\"text\":\"The Bahamas has the talent, the ambition, and the opportunity to be among the most dynamic nations in this region. What it has needed is a dedicated focus on turning that potential into progress — and a ministry built specifically to do it. \\n\"},{\"id\":\"6a4565d8086e83eb4bf5bcea\",\"text\":\"The Ministry of Innovation and National Development (MIND) brings together strategy, modernization, innovation, and delivery under one mandate: to plan for the future, help government work better, prepare Bahamians for what’s coming, and make sure the work actually gets done.\"}],\"image\":{\"id\":11,\"alt\":\"A new Ministry. A clear mandate.\",\"caption\":null,\"prefix\":\"dev-assets\",\"folder\":null,\"updatedAt\":\"2026-07-01T19:09:09.132Z\",\"createdAt\":\"2026-07-01T19:09:09.132Z\",\"url\":\"https://dl0cve36duziq.cloudfront.net/about.webp\",\"thumbnailURL\":\"/api/media/file/about-300x226.webp\",\"filename\":\"about.webp\",\"mimeType\":\"image/webp\",\"filesize\":64986,\"width\":636,\"height\":480,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumbnail\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/about-300x226.webp\",\"width\":300,\"height\":226,\"mimeType\":\"image/webp\",\"filesize\":17274,\"filename\":\"about-300x226.webp\"},\"square\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/about-500x500.webp\",\"width\":500,\"height\":500,\"mimeType\":\"image/webp\",\"filesize\":53916,\"filename\":\"about-500x500.webp\"},\"small\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/about-600x453.webp\",\"width\":600,\"height\":453,\"mimeType\":\"image/webp\",\"filesize\":59232,\"filename\":\"about-600x453.webp\"},\"medium\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"large\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"xlarge\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"og\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}}},\"textImageSections\":[{\"id\":\"6a4565d8086e83eb4bf5bcef\",\"heading\":\"What we're here to do.\",\"image\":{\"id\":9,\"alt\":\"A Ministry built to deliver\",\"caption\":null,\"prefix\":\"dev-assets\",\"folder\":null,\"updatedAt\":\"2026-07-01T12:30:19.948Z\",\"createdAt\":\"2026-07-01T12:30:19.948Z\",\"url\":\"https://dl0cve36duziq.cloudfront.net/ministry-robotic-hand.webp\",\"thumbnailURL\":\"/api/media/file/ministry-robotic-hand-300x255.webp\",\"filename\":\"ministry-robotic-hand.webp\",\"mimeType\":\"image/webp\",\"filesize\":42154,\"width\":700,\"height\":594,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumbnail\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/ministry-robotic-hand-300x255.webp\",\"width\":300,\"height\":255,\"mimeType\":\"image/webp\",\"filesize\":12126,\"filename\":\"ministry-robotic-hand-300x255.webp\"},\"square\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/ministry-robotic-hand-500x500.webp\",\"width\":500,\"height\":500,\"mimeType\":\"image/webp\",\"filesize\":27416,\"filename\":\"ministry-robotic-hand-500x500.webp\"},\"small\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/ministry-robotic-hand-600x509.webp\",\"width\":600,\"height\":509,\"mimeType\":\"image/webp\",\"filesize\":32804,\"filename\":\"ministry-robotic-hand-600x509.webp\"},\"medium\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"large\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"xlarge\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"og\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"imagePosition\":\"left\",\"text\":[{\"id\":\"6a4565d8086e83eb4bf5bceb\",\"text\":\"MIND is the Government’s strategy, modernization, innovation, and delivery ministry.\"},{\"id\":\"6a4565d8086e83eb4bf5bcec\",\"text\":\"Our job is to help The Bahamas prepare for the future, solve national challenges, and deliver measurable progress. \"},{\"id\":\"6a4565d8086e83eb4bf5bced\",\"text\":\"That means identifying the country’s most important priorities, developing practical solutions, coordinating action across government and society, and making sure those solutions are actually delivered.\"},{\"id\":\"6a4565d8086e83eb4bf5bcee\",\"text\":\"We are not a technology ministry. We are not a planning shop that produces reports. We are a delivery and coordination ministry — and we will be judged by what changes, not by what gets announced.\"}]},{\"id\":\"6a4565d8086e83eb4bf5bcf3\",\"heading\":\"Why this matters for your life.\",\"image\":{\"id\":12,\"alt\":\"Why this matters for your life\",\"caption\":null,\"prefix\":\"dev-assets\",\"folder\":null,\"updatedAt\":\"2026-07-01T19:09:09.128Z\",\"createdAt\":\"2026-07-01T19:09:09.125Z\",\"url\":\"https://dl0cve36duziq.cloudfront.net/why-matters.webp\",\"thumbnailURL\":\"/api/media/file/why-matters-300x255.webp\",\"filename\":\"why-matters.webp\",\"mimeType\":\"image/webp\",\"filesize\":48554,\"width\":700,\"height\":594,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumbnail\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/why-matters-300x255.webp\",\"width\":300,\"height\":255,\"mimeType\":\"image/webp\",\"filesize\":12798,\"filename\":\"why-matters-300x255.webp\"},\"square\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/why-matters-500x500.webp\",\"width\":500,\"height\":500,\"mimeType\":\"image/webp\",\"filesize\":31526,\"filename\":\"why-matters-500x500.webp\"},\"small\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/why-matters-600x509.webp\",\"width\":600,\"height\":509,\"mimeType\":\"image/webp\",\"filesize\":38136,\"filename\":\"why-matters-600x509.webp\"},\"medium\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"large\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"xlarge\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"og\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"imagePosition\":\"right\",\"text\":[{\"id\":\"6a4565d8086e83eb4bf5bcf0\",\"text\":\"Innovation, technology, and plans are not the goal. They are the tools. \"},{\"id\":\"6a4565d8086e83eb4bf5bcf1\",\"text\":\"The goal is a government that gives you your time back — faster services, simpler processes, fewer trips to an office to do something you should be able to do from your phone. The goal is a country better prepared for a world that is changing faster than any previous generation has had to navigate — so that we build an economy that creates more opportunities for more Bahamians, on every island, in every industry.\"},{\"id\":\"6a4565d8086e83eb4bf5bcf2\",\"text\":\"When government works better, it costs less time and money to do business. When people have the skills the future demands, they earn more and build more. When national planning is backed by real delivery, the next generation inherits a stronger country. \"},{\"id\":\"6a4a18d00d816b2cf13adfea\",\"text\":\"That is what this Ministry exists to do.\"}]}],\"mission\":{\"heading\":\"Everything we do points in one direction.\",\"description\":\"Expanding opportunity — so that more Bahamians can participate, succeed, and prosper, no matter where they live or what they're starting from.\",\"cards\":[{\"id\":\"6a4565d8086e83eb4bf5bcf4\",\"icon\":\"briefcase\",\"title\":\"Modernize Government\",\"description\":\"Make government faster, simpler, and more effective — so it works for you, not against you. That means digital services you can access from anywhere, processes that don't waste your time, and a government that is genuinely more responsive and accountable.\"},{\"id\":\"6a4565d8086e83eb4bf5bcf5\",\"icon\":\"briefcase\",\"title\":\"Build Future Readiness\",\"description\":\"Prepare the country for what's ahead — a renewed national development plan, responsible AI governance, and the connectivity that reaches every island. This is how The Bahamas positions itself for the industries and technologies shaping the next decade.\"},{\"id\":\"6a4565d8086e83eb4bf5bcf6\",\"icon\":\"briefcase\",\"title\":\"Develop Bahamian Talent\",\"description\":\"Equip Bahamians with the skills the future demands — AI literacy, technology training, and pathways into the industries of tomorrow. A nation that grows its own talent is a nation that owns its own future.\"},{\"id\":\"6a4565d8086e83eb4bf5bcf7\",\"icon\":\"briefcase\",\"title\":\"Drive National Development\",\"description\":\"Turn national priorities into measurable outcomes, with the institutions to back it up — a living national plan, a dedicated delivery team, and the data and accountability systems to track real progress.\"}]},\"dualCta\":{\"first\":{\"heading\":\"We'd rather show you than tell you\",\"description\":\"This Ministry is new. We are not going to ask you to take our word for it. \\nWe will publish what we’re working on, what we’ve delivered, and — when things take longer than planned — why. Progress is a live page on this site, and it tells the honest story: what is live, what is in progress, and what is still being built. \\nSuccess, for us, is not measured by the number of initiatives launched or strategies published. It is measured by what actually changes for Bahamians. That is the standard we hold ourselves to, and we are happy to be held to it.\",\"button\":{\"label\":\"See what's already in motion →\",\"href\":\"/progress\"}},\"second\":{\"heading\":\"Building on what The Bahamas already set out to become.\",\"description\":\"Vision 2040 set a clear course for this country — more competitive, more innovative, better prepared for the future. This Ministry is built to renew that vision and help deliver it. \\nThe work ahead builds directly on that foundation.\",\"button\":{\"label\":\"Learn more about Vision 2040 →\",\"href\":\"/progress\"}}},\"policyAreas\":{\"heading\":\"Policy areas this Ministry leads\",\"cta\":{\"label\":\"See all policies →\",\"href\":\"/policies\"},\"policies\":[{\"id\":\"6a4565d8086e83eb4bf5bcf8\",\"label\":\"Artificial Intelligence\",\"status\":\"active\",\"href\":\"/policies/artificial-Intelligence\"},{\"id\":\"6a4565d8086e83eb4bf5bcf9\",\"label\":\"Digital Economy\",\"status\":\"comingSoon\",\"href\":\"/policies/digital-economy\"},{\"id\":\"6a4565d8086e83eb4bf5bcfa\",\"label\":\"Digital Innovation and Infrastructure\",\"status\":\"comingSoon\",\"href\":\"/policies/digital-infrastructure\"},{\"id\":\"6a4565d8086e83eb4bf5bcfb\",\"label\":\"E-Government\",\"status\":\"comingSoon\",\"href\":\"/policies/cybersecurity\"},{\"id\":\"6a4565d8086e83eb4bf5bcfc\",\"label\":\"Ease of Doing Business\",\"status\":\"comingSoon\",\"href\":\"/policies/data-privacy\"},{\"id\":\"6a4565d8086e83eb4bf5bcfd\",\"label\":\"e-Commerce\",\"status\":\"comingSoon\",\"href\":\"/policies/egovernment\"},{\"id\":\"6a4565d8086e83eb4bf5bcfe\",\"label\":\"Electronic Communication Sector\",\"status\":\"comingSoon\",\"href\":\"/policies/digital-literacy\"},{\"id\":\"6a4565d8086e83eb4bf5bcff\",\"label\":\"Future Readiness\",\"status\":\"active\",\"href\":\"/policies/future-readiness\"},{\"id\":\"6a4565d8086e83eb4bf5bd00\",\"label\":\"Innovative Solutions\",\"status\":\"comingSoon\",\"href\":\"/policies/innovation\"},{\"id\":\"6a4565d8086e83eb4bf5bd01\",\"label\":\"National Development Planning\",\"status\":\"active\",\"href\":\"/policies/national-development-planning\"},{\"id\":\"6a4565d8086e83eb4bf5bd02\",\"label\":\"National Digital ID\",\"status\":\"active\",\"href\":\"/policies/national-digital-id\"},{\"id\":\"6a4565d8086e83eb4bf5bd03\",\"label\":\"Space Industry\",\"status\":\"comingSoon\",\"href\":\"/policies/urban-planning\"},{\"id\":\"6a4565d8086e83eb4bf5bd04\",\"label\":\"Workforce Development\",\"status\":\"active\",\"href\":\"/policies/workforce-development\"}]},\"departments\":{\"heading\":\"What falls under this Ministry.\",\"description\":\"Expanding opportunity — so that more Bahamians can participate, succeed, and prosper, no matter where they live or what they're starting from.\",\"items\":[{\"id\":\"6a4565d8086e83eb4bf5bd05\",\"icon\":\"briefcase\",\"title\":\"Department of Information & Communications Technology (DICT)\",\"description\":\"Leading government digital transformation, technology infrastructure, and the systems that power modern public service delivery across The Bahamas.\",\"linkLabel\":\"dict.gov.bs\",\"href\":\"/departments/dict\"},{\"id\":\"6a4565d8086e83eb4bf5bd06\",\"icon\":\"briefcase\",\"title\":\"MyGateway\",\"description\":\"The national digital platform giving Bahamians access to 150+ government services in one place — reducing time, cost, and complexity.\",\"linkLabel\":\"mygateway.gov.bs\",\"href\":\"/mygateway\"},{\"id\":\"6a4565d8086e83eb4bf5bd07\",\"icon\":\"briefcase\",\"title\":\"Bahamas National Statistical Institute (BNSI)\",\"description\":\"is the country’s independent data and statistics body — the evidence backbone that grounds national decisions in fact.\",\"linkLabel\":\"bnsi.stats.gov.bs\",\"href\":\"/departments/bnsi\"},{\"id\":\"6a4565d8086e83eb4bf5bd08\",\"icon\":\"briefcase\",\"title\":\"National Development Plan Secretariat\",\"description\":\"Turn national priorities into measurable outcomes, with the institutions to back it up — a living national plan, a dedicated delivery team, and the data and accountability systems to track real progress.\",\"linkLabel\":\"Learn more\",\"href\":\"/departments/electronic-communications\"}]},\"ministerProfiles\":[{\"id\":\"6a4565d8086e83eb4bf5bd0c\",\"label\":\"The Minister\",\"name\":\"Hon. Sebastian J. Bastian\",\"title\":\"Minister of Innovation and National Development Member of Parliament, Fort Charlotte\",\"image\":{\"id\":6,\"alt\":\"Hon. Sebastian J. Bastian\",\"caption\":null,\"prefix\":\"dev-assets\",\"folder\":null,\"updatedAt\":\"2026-07-01T12:30:19.906Z\",\"createdAt\":\"2026-07-01T12:30:19.906Z\",\"url\":\"https://dl0cve36duziq.cloudfront.net/minister-portrait.webp\",\"thumbnailURL\":\"/api/media/file/minister-portrait-300x200.webp\",\"filename\":\"minister-portrait.webp\",\"mimeType\":\"image/webp\",\"filesize\":38226,\"width\":1600,\"height\":1066,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumbnail\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/minister-portrait-300x200.webp\",\"width\":300,\"height\":200,\"mimeType\":\"image/webp\",\"filesize\":3122,\"filename\":\"minister-portrait-300x200.webp\"},\"square\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/minister-portrait-500x500.webp\",\"width\":500,\"height\":500,\"mimeType\":\"image/webp\",\"filesize\":10690,\"filename\":\"minister-portrait-500x500.webp\"},\"small\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/minister-portrait-600x400.webp\",\"width\":600,\"height\":400,\"mimeType\":\"image/webp\",\"filesize\":7606,\"filename\":\"minister-portrait-600x400.webp\"},\"medium\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/minister-portrait-900x600.webp\",\"width\":900,\"height\":600,\"mimeType\":\"image/webp\",\"filesize\":14070,\"filename\":\"minister-portrait-900x600.webp\"},\"large\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/minister-portrait-1400x933.webp\",\"width\":1400,\"height\":933,\"mimeType\":\"image/webp\",\"filesize\":30356,\"filename\":\"minister-portrait-1400x933.webp\"},\"xlarge\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"og\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/minister-portrait-1200x630.webp\",\"width\":1200,\"height\":630,\"mimeType\":\"image/webp\",\"filesize\":20844,\"filename\":\"minister-portrait-1200x630.webp\"}}},\"bio\":[{\"id\":\"6a4565d8086e83eb4bf5bd09\",\"text\":\"Hon. Sebastian Bastian brings a builder's mindset to public service, focused on delivering practical solutions and measurable results.\"},{\"id\":\"6a4565d8086e83eb4bf5bd0a\",\"text\":\"As Minister of Innovation and National Development, he is leading efforts to modernize government services, strengthen infrastructure, and create opportunities for Bahamians. \"},{\"id\":\"6a4565d8086e83eb4bf5bd0b\",\"text\":\"His mission is clear: transform ideas into action and deliver lasting progress for communities across the nation.\"}]},{\"id\":\"6a4565d8086e83eb4bf5bd10\",\"label\":\"The Minister of State\",\"name\":\"Hon. Wayde Alexander Watson\",\"title\":\"Minister of State for Innovation and National Development\",\"image\":{\"id\":13,\"alt\":\"Hon. Wayde Alexander Watson\",\"caption\":null,\"prefix\":\"dev-assets\",\"folder\":null,\"updatedAt\":\"2026-07-01T19:09:12.243Z\",\"createdAt\":\"2026-07-01T19:09:12.242Z\",\"url\":\"https://dl0cve36duziq.cloudfront.net/minister-wayne.webp\",\"thumbnailURL\":\"/api/media/file/minister-wayne-300x200.webp\",\"filename\":\"minister-wayne.webp\",\"mimeType\":\"image/webp\",\"filesize\":262666,\"width\":3507,\"height\":2338,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumbnail\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/minister-wayne-300x200.webp\",\"width\":300,\"height\":200,\"mimeType\":\"image/webp\",\"filesize\":3696,\"filename\":\"minister-wayne-300x200.webp\"},\"square\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/minister-wayne-500x500.webp\",\"width\":500,\"height\":500,\"mimeType\":\"image/webp\",\"filesize\":12448,\"filename\":\"minister-wayne-500x500.webp\"},\"small\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/minister-wayne-600x400.webp\",\"width\":600,\"height\":400,\"mimeType\":\"image/webp\",\"filesize\":8906,\"filename\":\"minister-wayne-600x400.webp\"},\"medium\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/minister-wayne-900x600.webp\",\"width\":900,\"height\":600,\"mimeType\":\"image/webp\",\"filesize\":16710,\"filename\":\"minister-wayne-900x600.webp\"},\"large\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/minister-wayne-1400x933.webp\",\"width\":1400,\"height\":933,\"mimeType\":\"image/webp\",\"filesize\":37132,\"filename\":\"minister-wayne-1400x933.webp\"},\"xlarge\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/minister-wayne-1920x1280.webp\",\"width\":1920,\"height\":1280,\"mimeType\":\"image/webp\",\"filesize\":69550,\"filename\":\"minister-wayne-1920x1280.webp\"},\"og\":{\"url\":\"https://dl0cve36duziq.cloudfront.net/minister-wayne-1200x630.webp\",\"width\":1200,\"height\":630,\"mimeType\":\"image/webp\",\"filesize\":24774,\"filename\":\"minister-wayne-1200x630.webp\"}}},\"bio\":[{\"id\":\"6a4565d8086e83eb4bf5bd0d\",\"text\":\"As Minister of State for Innovation and National Development, Hon. Wayde Alexander Watson plays a key role in advancing the Ministry's priorities and supporting national development initiatives. Working closely with government partners and communities, [he/she] is focused on delivering practical solutions and improving public services.\\n\"},{\"id\":\"6a4565d8086e83eb4bf5bd0e\",\"text\":\"\\nThrough collaborative leadership and a commitment to results, he helps drive innovation, create opportunities, and support meaningful progress for Bahamians across the nation.\"}]}],\"countryFuture\":{\"heading\":\"This is your Ministry too.\",\"subtitle\":\"We work for the people of The Bahamas. That means being open about what we’re doing, honest about where we are, and ready to hear from you.\",\"primaryButton\":{\"label\":\"See what's already moving →\",\"href\":\"/updates\"},\"secondaryButton\":{\"label\":\"Get involved\",\"href\":\"/contact\"}},\"meta\":{\"title\":null,\"image\":null,\"description\":null},\"updatedAt\":\"2026-07-06T06:19:33.750Z\",\"createdAt\":\"2026-07-01T19:09:12.641Z\",\"globalType\":\"about-page\"}","status":200,"url":""},"revalidate":31536000,"tags":["global_about-page"]}